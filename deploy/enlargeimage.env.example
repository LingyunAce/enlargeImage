# /etc/enlargeimage/enlargeimage.env
# Copy to /etc/enlargeimage/enlargeimage.env and uncomment/edit.

# Bind address
# HOST=0.0.0.0
# PORT=8000

# Model weights directory (must contain SwinIR_REALSR_X{scale}.pth files)
# MODEL_DIR=/opt/enlargeimage/backend/models

# Per-job input/output storage
# STORAGE_DIR=/opt/enlargeimage/backend/storage

# SQLite database file
# DB_PATH=/opt/enlargeimage/backend/data.db

# Number of uvicorn workers (1 recommended for CPU-bound SwinIR)
# WORKERS=1

# Logging
# LOG_LEVEL=info
